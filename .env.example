MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/suncola?retryWrites=true&w=majority
SUPER_ADMIN_EMAIL=admin@suncola.com
SUPER_ADMIN_PASSWORD=your_secure_password
PORT=3000

# Cloudflare Zero Trust Tunnel Token
CLOUDFLARE_TOKEN=your_cloudflare_tunnel_token_here

# SMTP Configuration (for sending emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
